# ============================================================================
# Far Horizon — Unity 6 (6000.4.10f1) / URP .gitignore
# Authored BEFORE the first commit so no throwaway artifacts ever enter history.
# ============================================================================

# Unity-generated (regenerable from the project + Library import)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Verification / soak artifacts (regenerable from batchmode + the build)
/Captures/
*.log
test-results.xml
test-results-*.xml

# Visual Studio / Rider / VS Code generated project files
/.vs/
/.idea/
/.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D-generated meta files of folders that are themselves ignored
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# Autogenerated crashlog / Burst
sysinfo.txt
crashlog.txt
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
__pycache__/
*.pyc

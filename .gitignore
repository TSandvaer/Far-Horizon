# ============================================================================
# Far Horizon — Unity 6 (6000.4.11f1) / URP .gitignore
# Authored BEFORE the first commit so no throwaway artifacts ever enter history.
# ============================================================================

# Unity-generated (regenerable from the project + Library import)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Verification / soak artifacts (regenerable from batchmode + the build)
/Captures/
/VerifyCaptures/
/ci-out/
*.log
test-results.xml
test-results-*.xml
# NUnit result XMLs written by local -runTests runs (e.g. editmode-results.xml).
*-results.xml

# Visual Studio / Rider / VS Code generated project files
/.vs/
/.idea/
/.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D-generated meta files of folders that are themselves ignored
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# Autogenerated crashlog / Burst
sysinfo.txt
crashlog.txt
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Throwaway local verification output (bootstrap/test/build logs + capture PNGs).
# Author-side shipped-build evidence dirs; never committed (structure_check.sh also blocks
# Captures/ and *.log/test-results) — capture evidence lives in the PR Self-Test Report.
/_u5_out/
/_verify_out/

# Blender working backups + throwaway debug render outputs. The FBX + palette PNG are
# the Unity-imported deliverables; the .blend modeling source lives in art-src/ (outside
# Assets/ so Unity never imports it). Stray .blend/.blend1 + their Unity-generated .meta
# must never land under Assets/Art/Props/WeaponPack.
*.blend1
/tools/debug/axe_*.png
/Assets/Art/Props/WeaponPack/*.blend
/Assets/Art/Props/WeaponPack/*.blend.meta
/Assets/Art/Props/WeaponPack/*.blend1.meta

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
__pycache__/
*.pyc

# Downloaded CI build artifacts (held-pose capture source — never commit)
team/devon-dev/_ci_build*/
/ci-local/
